<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if title %}{{ title }} - {% endif %}{{ site.title }}</title>
    <meta name="description" content="{{ description or summary or site.description }}" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&amp;family=Manrope:wght@400;500;600;700;800&amp;display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="{{ '/assets/styles.css' | url }}" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="brand" href="{{ '/' | url }}">{{ site.productName }}</a>
        <div class="header-actions">
          <a class="header-link" href="{{ site.npmUrl }}">npm</a>
          <a class="header-link" href="{{ site.repositoryUrl }}">GitHub</a>
        </div>
        <button
          class="nav-toggle"
          id="docs-nav-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="docs-sidebar"
          aria-label="Toggle site navigation"
          hidden
        >
          <span class="nav-toggle-icon" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </button>
      </div>
    </header>

    <div class="docs-shell">
      <aside class="sidebar" id="docs-sidebar" aria-label="Site navigation">
        <div class="sidebar-group">
          <p class="sidebar-label">Start here</p>
          <a href="{{ '/' | url }}" {% if page.url == '/' %}aria-current="page"{% endif %}>
            What gitrole does
          </a>
        </div>

        <div class="sidebar-group">
          <p class="sidebar-label">Guides</p>
          {% for entry in collections.guides %}
            <a href="{{ entry.url | url }}" {% if page.url == entry.url %}aria-current="page"{% endif %}>
              {{ entry.data.title }}
            </a>
          {% endfor %}
        </div>

        <div class="sidebar-group">
          <p class="sidebar-label">Use cases</p>
          {% for entry in collections.useCases %}
            <a href="{{ entry.url | url }}" {% if page.url == entry.url %}aria-current="page"{% endif %}>
              {{ entry.data.title }}
            </a>
          {% endfor %}
        </div>

        <div class="sidebar-group">
          <p class="sidebar-label">Reference</p>
          <a href="{{ '/commands/' | url }}" {% if page.url == '/commands/' %}aria-current="page"{% endif %}>
            Commands
          </a>
        </div>

        <div class="sidebar-group sidebar-group-mobile-only">
          <p class="sidebar-label">Project</p>
          <a href="{{ site.repositoryUrl }}">Repository</a>
          <a href="{{ site.npmUrl }}">npm package</a>
          <a href="https://github.com/synsoftworks/gitrole/blob/main/README.md">README</a>
        </div>
      </aside>

      <main class="docs-main">
        <article class="doc">
          {% if eyebrow or title %}
            <header class="page-intro">
              {% if eyebrow %}
                <p class="eyebrow">{{ eyebrow }}</p>
              {% endif %}
              {% if title %}
                <h1>{{ title }}</h1>
              {% endif %}
              {% if summary %}
                <p class="lede">{{ summary }}</p>
              {% endif %}
              {% if coverImage %}
                <img class="cover-image" src="{{ coverImage | url }}" alt="" />
              {% endif %}
            </header>
          {% endif %}

          <div class="doc-content">
            {{ content | safe }}
          </div>
        </article>
      </main>
    </div>

    <script>
      (() => {
        const root = document.documentElement;
        const toggle = document.getElementById('docs-nav-toggle');
        const sidebar = document.getElementById('docs-sidebar');

        if (!toggle || !sidebar) {
          return;
        }

        root.dataset.docsNav = 'ready';
        toggle.hidden = false;

        const setExpanded = (expanded) => {
          toggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
          root.dataset.docsNavOpen = expanded ? 'true' : 'false';
        };

        setExpanded(false);

        toggle.addEventListener('click', () => {
          setExpanded(toggle.getAttribute('aria-expanded') !== 'true');
        });

        sidebar.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => {
            if (window.innerWidth <= 960) {
              setExpanded(false);
            }
          });
        });

        window.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') {
            setExpanded(false);
          }
        });

        window.addEventListener('resize', () => {
          if (window.innerWidth > 960) {
            setExpanded(false);
          }
        });
      })();
    </script>
  </body>
</html>
